        <mxCell id="S2" value="CHALLENGE_WINDOW&#xa;objections, evidence,&#xa;revision requests" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf3ff;strokeWidth=2;" vertex="1" parent="1">
